<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <!-- Same recipe as the assistant bubble, but pinned to the end (bias=1) for outgoing messages. -->
    <TextView
        android:id="@+id/textMessageBody"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bubble_user_background"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="?attr/colorOnPrimaryContainer"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="wrap"
        app:layout_constraintWidth_percent="0.8"
        tools:text="Hey, what's the weather like today?" />

</androidx.constraintlayout.widget.ConstraintLayout>
